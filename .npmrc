# vite-plugin-pwa@1.2.0 declares its peer dependency as vite ^3..^7.
# Until upstream releases a version with vite 8 support, npm rejects the
# peer-dep range mismatch on strict `npm ci` (e.g. on Cloudflare's build
# environment). The `overrides` block in package.json fixes resolution but
# doesn't rewrite the recorded peer range — so we relax peer enforcement
# globally here. Remove this file once vite-plugin-pwa adopts vite 8.
legacy-peer-deps=true
